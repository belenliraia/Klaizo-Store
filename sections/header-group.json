      "settings": {
        "custom_liquid": "<style>\n.kzt *, .kzt *::before, .kzt *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n.kzt-ticker {\n  background: #111111;\n  border-top: 1px solid rgba(255,255,255,0.07);\n  border-bottom: 1px solid rgba(255,255,255,0.07);\n  overflow: hidden;\n  padding: 13px 0;\n  position: relative;\n  z-index: 10;\n}\n\n.kzt-track {\n  display: flex;\n  width: max-content;\n  animation: kztScroll 28s linear infinite;\n}\n.kzt-track:hover { animation-play-state: paused; }\n\n.kzt-group {\n  display: flex;\n  align-items: center;\n  gap: 0;\n  flex-shrink: 0;\n}\n\n.kzt-item {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  padding: 0 28px;\n  font-family: 'Inter', sans-serif;\n  font-size: 13px;\n  font-weight: 500;\n  color: #c0c0c0;\n  white-space: nowrap;\n  letter-spacing: 0.01em;\n}\n\n.kzt-item svg {\n  width: 14px;\n  height: 14px;\n  color: #E8001D;\n  flex-shrink: 0;\n}\n\n.kzt-sep {\n  width: 4px;\n  height: 4px;\n  background: #E8001D;\n  border-radius: 50%;\n  flex-shrink: 0;\n  opacity: 0.6;\n}\n\n@keyframes kztScroll {\n  from { transform: translateX(0); }\n  to   { transform: translateX(-50%); }\n}\n\n@media (max-width: 640px) {\n  .kzt-item { font-size: 12px; padding: 0 20px; }\n  .kzt-ticker { padding: 11px 0; }\n}\n</style>\n\n<div class=\"kzt\">\n  <div class=\"kzt-ticker\">\n    <div class=\"kzt-track\">\n      <!-- Grupo 1 -->\n      <div class=\"kzt-group\">\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Soporte chileno\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Compatible con autos y motos\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Compacto y portátil\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Despacho 24-48h\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Envío rápido a todo Chile\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Garantía oficial 30 días\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Pago 100% seguro\n        </div>\n        <div class=\"kzt-sep\"></div>\n      </div>\n      <!-- Grupo 2 (copia exacta para loop infinito) -->\n      <div class=\"kzt-group\">\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Soporte chileno\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Compatible con autos y motos\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Compacto y portátil\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Despacho 24-48h\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Envío rápido a todo Chile\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Garantía oficial 30 días\n        </div>\n        <div class=\"kzt-sep\"></div>\n        <div class=\"kzt-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Pago 100% seguro\n        </div>\n        <div class=\"kzt-sep\"></div>\n      </div>\n    </div>\n  </div>\n</div>",
