\" onclick=\"kzhClose()\">Envíos</a>\n      <a href=\"#garantia\" onclick=\"kzhClose()\">Garantía</a>\n      <a href=\"#faq\" onclick=\"kzhClose()\">FAQ</a>\n      <a href=\"#contacto\" onclick=\"kzhClose()\">Contacto</a>\n      <a href=\"https://klaizo.com/products/partidor-bateria-auto-compresor-multifun\" class=\"kzh-mobile-buy\">Comprar ahora</a>\n    </div>\n  </header>\n</div>\n\n<script>\n(function(){\n  var burger = document.getElementById('kzhBurger');\n  var mnav = document.getElementById('kzhMobileNav');\n  var isOpen = false;\n  function kzhClose(){\n    isOpen = false;\n    burger.classList.remove('open');\n    mnav.classList.remove('open');\n    setTimeout(function(){ mnav.style.display = ''; }, 300);\n  }\n  window.kzhClose = kzhClose;\n  burger.addEventListener('click', function(){\n    isOpen = !isOpen;\n    burger.classList.toggle('open', isOpen);\n    if(isOpen){ mnav.style.display = 'flex'; setTimeout(function(){ mnav.classList.add('open'); }, 10); }\n    else { kzhClose(); }\n  });\n})();\n</script>",
