    "custom_liquid_L6ULkt": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .klaizo-faq {\n    background: #111111;\n    padding: 90px 40px;\n    font-family: 'Barlow', sans-serif;\n    box-sizing: border-box;\n  }\n  .klaizo-faq * { box-sizing: border-box; }\n\n  .klaizo-faq__inner {\n    max-width: 1100px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 320px 1fr;\n    gap: 60px;\n    align-items: start;\n  }\n\n  .klaizo-faq__label {\n    color: #e8392a;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    margin: 0 0 16px;\n  }\n\n  .klaizo-faq__heading {\n    font-family: 'Bebas Neue', sans-serif;\n    font-size: clamp(42px, 4.5vw, 58px);\n    line-height: 1.0;\n    color: #ffffff;\n    margin: 0 0 20px;\n  }\n\n  .klaizo-faq__sub {\n    color: rgba(255,255,255,0.45);\n    font-size: 14px;\n    line-height: 1.6;\n    margin: 0;\n  }\n\n  .klaizo-faq__list {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n\n  .klaizo-faq__item {\n    background: #1a1a1a;\n    border: 1px solid #2a2a2a;\n    border-radius: 12px;\n    overflow: hidden;\n    transition: border-color 0.25s ease;\n  }\n\n  .klaizo-faq__item.is-open {\n    border-color: rgba(232,57,42,0.35);\n  }\n\n  .klaizo-faq__question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 20px 24px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    cursor: pointer;\n    text-align: left;\n  }\n\n  .klaizo-faq__question-text {\n    color: #ffffff;\n    font-family: 'Barlow', sans-serif;\n    font-size: 15px;\n    font-weight: 600;\n    margin: 0;\n    line-height: 1.3;\n  }\n\n  .klaizo-faq__icon {\n    flex-shrink: 0;\n    width: 24px;\n    height: 24px;\n    border-radius: 50%;\n    border: 1px solid #3a3a3a;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background 0.25s ease, border-color 0.25s ease, transform 0.3s ease;\n  }\n\n  .klaizo-faq__icon svg {\n    width: 12px;\n    height: 12px;\n    stroke: rgba(255,255,255,0.5);\n    transition: stroke 0.25s ease, transform 0.3s ease;\n  }\n\n  .klaizo-faq__item.is-open .klaizo-faq__icon {\n    background: #e8392a;\n    border-color: #e8392a;\n    transform: rotate(180deg);\n  }\n\n  .klaizo-faq__item.is-open .klaizo-faq__icon svg {\n    stroke: #ffffff;\n  }\n\n  .klaizo-faq__answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.4s ease, padding 0.3s ease;\n    padding: 0 24px;\n  }\n\n  .klaizo-faq__item.is-open .klaizo-faq__answer {\n    max-height: 200px;\n    padding: 0 24px 20px;\n  }\n\n  .klaizo-faq__answer p {\n    color: rgba(255,255,255,0.6);\n    font-size: 14px;\n    line-height: 1.7;\n    margin: 0;\n    border-top: 1px solid #2a2a2a;\n    padding-top: 16px;\n  }\n\n  @media (max-width: 768px) {\n    .klaizo-faq { padding: 60px 20px; }\n    .klaizo-faq__inner {\n      grid-template-columns: 1fr;\n      gap: 36px;\n    }\n  }\n</style>\n\n<section class=\"klaizo-faq\">\n  <div class=\"klaizo-faq__inner\">\n\n    <div class=\"klaizo-faq__left\">\n      <p class=\"klaizo-faq__label\">FAQ</p>\n      <h2 class=\"klaizo-faq__heading\">Preguntas<br>frecuentes</h2>\n      <p class=\"klaizo-faq__sub\">¿No encuentras lo que buscas? Escríbenos y te respondemos rápido.</p>\n    </div>\n\n    <div class=\"klaizo-faq__list\">\n\n      <div class=\"klaizo-faq__item\">\n        <button class=\"klaizo-faq__question\" onclick=\"klaizoToggle(this)\">\n          <span class=\"klaizo-faq__question-text\">¿Sirve para cualquier auto?</span>\n          <span class=\"klaizo-faq__icon\">\n            <svg viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M2 4L6 8L10 4\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n        </button>\n        <div class=\"klaizo-faq__answer\">\n          <p>Sí. KLAIZO PowerGo está diseñado para vehículos de hasta 6.0L bencinero y 4.0L diésel, lo que cubre prácticamente todos los autos, camionetas y motos del mercado.</p>\n        </div>\n      </div>\n\n      <div class=\"klaizo-faq__item\">\n        <button class=\"klaizo-faq__question\" onclick=\"klaizoToggle(this)\">\n          <span class=\"klaizo-faq__question-text\">¿Cuántas veces puede arrancar un vehículo?</span>\n          <span class=\"klaizo-faq__icon\">\n            <svg viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M2 4L6 8L10 4\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n        </button>\n        <div class=\"klaizo-faq__answer\">\n          <p>A carga completa puede realizar entre 20 y 30 arranques consecutivos antes de necesitar recarga.</p>\n        </div>\n      </div>\n\n      <div class=\"klaizo-faq__item\">\n        <button class=\"klaizo-faq__question\" onclick=\"klaizoToggle(this)\">\n          <span class=\"klaizo-faq__question-text\">¿Incluye cables?</span>\n          <span class=\"klaizo-faq__icon\">\n            <svg viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M2 4L6 8L10 4\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n        </button>\n        <div class=\"klaizo-faq__answer\">\n          <p>Sí. Incluye cables de pinzas inteligentes, cable USB-C de carga, manguera para compresor con adaptadores y estuche de transporte.</p>\n        </div>\n      </div>\n\n      <div class=\"klaizo-faq__item\">\n        <button class=\"klaizo-faq__question\" onclick=\"klaizoToggle(this)\">\n          <span class=\"klaizo-faq__question-text\">¿Cuánto dura la batería?</span>\n          <span class=\"klaizo-faq__icon\">\n            <svg viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M2 4L6 8L10 4\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n        </button>\n        <div class=\"klaizo-faq__answer\">\n          <p>La batería interna de litio mantiene su carga hasta 12 meses sin uso, lista para responder cuando la necesites.</p>\n        </div>\n      </div>\n\n      <div class=\"klaizo-faq__item\">\n        <button class=\"klaizo-faq__question\" onclick=\"klaizoToggle(this)\">\n          <span class=\"klaizo-faq__question-text\">¿Sirve para motos?</span>\n          <span class=\"klaizo-faq__icon\">\n            <svg viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M2 4L6 8L10 4\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n        </button>\n        <div class=\"klaizo-faq__answer\">\n          <p>Sí. Es compatible con motocicletas, jet skis, cuatrimotos y embarcaciones menores.</p>\n        </div>\n      </div>\n\n      <div class=\"klaizo-faq__item\">\n        <button class=\"klaizo-faq__question\" onclick=\"klaizoToggle(this)\">\n          <span class=\"klaizo-faq__question-text\">¿Tiene garantía?</span>\n          <span class=\"klaizo-faq__icon\">\n            <svg viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M2 4L6 8L10 4\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n        </button>\n        <div class=\"klaizo-faq__answer\">\n          <p>Sí. Ofrecemos 30 días de garantía oficial KLAIZO con cambio o devolución sin preguntas.</p>\n        </div>\n      </div>\n\n      <div class=\"klaizo-faq__item\">\n        <button class=\"klaizo-faq__question\" onclick=\"klaizoToggle(this)\">\n          <span class=\"klaizo-faq__question-text\">¿Cuánto demora el envío?</span>\n          <span class=\"klaizo-faq__icon\">\n            <svg viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M2 4L6 8L10 4\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n        </button>\n        <div class=\"klaizo-faq__answer\">\n          <p>Despachamos en 24h. Llegada estimada de 2 a 5 días hábiles dependiendo de tu ciudad en Chile.</p>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<script>\n  function klaizoToggle(btn) {\n    var item = btn.closest('.klaizo-faq__item');\n    var isOpen = item.classList.contains('is-open');\n    document.querySelectorAll('.klaizo-faq__item.is-open').forEach(function(el) {\n      el.classList.remove('is-open');\n    });\n    if (!isOpen) {\n      item.classList.add('is-open');\n    }\n  }\n</script>",
