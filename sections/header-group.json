form: translateY(-1px);\n}\n\n.kzh-cart {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 38px; height: 38px;\n  border-radius: 50%;\n  background: rgba(255,255,255,0.06);\n  border: 1px solid rgba(255,255,255,0.1);\n  color: var(--light);\n  text-decoration: none;\n  transition: background 0.2s;\n}\n.kzh-cart:hover { background: rgba(255,255,255,0.13); color: #fff; }\n.kzh-cart svg { width: 18px; height: 18px; }\n\n.kzh-hamburger {\n  display: none;\n  flex-direction: column;\n  gap: 5px;\n  justify-content: center;\n  width: 36px; height: 36px;\n  background: none;\n  border: none;\n  cursor: pointer;\n  padding: 4px;\n}\n.kzh-hamburger span {\n  display: block;\n  width: 22px; height: 2px;\n  background: #fff;\n  border-radius: 2px;\n  transition: transform 0.3s, opacity 0.3s;\n  transform-origin: center;\n}\n.kzh-hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }\n.kzh-hamburger.open span:nth-child(2) { opacity: 0; }\n.kzh-hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }\n\n.kzh-mobile-nav {\n  display: none;\n  position: fixed;\n  top: 64px; left: 0; right: 0;\n  z-index: 9998;\n  background: rgba(13,13,13,0.97);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border-bottom: 1px solid rgba(255,255,255,0.08);\n  padding: 12px 24px 24px;\n  flex-direction: column;\n  opacity: 0;\n  transform: translateY(-8px);\n  transition: opacity 0.3s, transform 0.3s;\n}\n.kzh-mobile-nav.open { opacity: 1; transform: translateY(0); }\n.kzh-mobile-nav a {\n  color: var(--light);\n  text-decoration: none;\n  font-family: var(--font);\n  font-size: 15px;\n  font-weight: 500;\n  padding: 14px 0;\n  border-bottom: 1px solid rgba(255,255,255,0.06);\n  display: block;\n  transition: color 0.2s;\n  cursor: pointer;\n}\n.kzh-mobile-nav a:hover { color: #fff; }\n.kzh-mobile-nav .kzh-mobile-buy {\n  margin-top: 16px;\n  display: block;\n  background: var(--red);\