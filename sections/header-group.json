lass=\"kzh-mobile-nav\" id=\"kzhMobileNav\">\n      <a onclick=\"kzhGo('inicio', this); kzhClose();\">Inicio</a>\n      <a href=\"https://klaizo.com/products/partidor-bateria-auto-compresor-multifun\" target=\"_blank\" onclick=\"kzhClose();\">Producto</a>\n      <a onclick=\"kzhGo('klaizo-demo', this); kzhClose();\">Beneficios</a>\n      <a onclick=\"kzhGo('klaizo-reviews', this); kzhClose();\">Reseñas</a>\n      <a onclick=\"kzhGo('klaizo-faq', this); kzhClose();\">FAQ</a>\n      <a href=\"https://klaizo.com/products/partidor-bateria-auto-compresor-multifun\" class=\"kzh-mobile-buy\">Comprar ahora</a>\n    </div>\n  </header>\n</div>\n\n<script>\n(function(){\n\n  var HEADER_H = 64;\n\n  window.kzhGo = function(className, linkEl) {\n    document.querySelectorAll('.kzh-nav a, .kzh-mobile-nav a').forEach(function(a){\n      a.classList.remove('kzh-active');\n    });\n    if(linkEl) linkEl.classList.add('kzh-active');\n\n    if(className === 'inicio') {\n      window.scrollTo({ top: 0, behavior: 'smooth' });\n      return;\n    }\n\n    var target = document.querySelector('.' + className);\n\n    if(!target) {\n      var all = document.querySelectorAll('.shopify-section');\n      for(var i = 0; i < all.length; i++){\n        var found = all[i].querySelector('[class*=\"' + className + '\"]');\n        if(found){ target = found; break; }\n      }\n    }\n\n    if(target){\n      var top = target.getBoundingClientRect().top + window.pageYOffset - HEADER_H - 8;\n      window.scrollTo({ top: top, behavior: 'smooth' });\n    }\n  };\n\n  /* Hamburger */\n  var burger = document.getElementById('kzhBurger');\n  var mnav   = document.getElementById('kzhMobileNav');\n  var isOpen = false;\n\n  function kzhClose(){\n    isOpen = false;\n    burger.classList.remove('open');\n    mnav.classList.remove('open');\n    setTimeout(function(){ mnav.style.display = ''; }, 300);\n  }\n  window.kzhClose = kzhClose;\n\n  burger.addEventListener('click', function(){\n    isOpen = !isOpen;\n    burger.classList.toggle('open', isOpen);\n    if(isOpen){\n      mnav.style.display = 'flex';\n      setTimeout(function(){ mnav.classList.add('open'); }, 10);\n    } else {\n      kzhClose();\n    }\n  });\n\n  /* Link activo al scrollear */\n  var scrollTargets = [\n    { cls: 'klaizo-demo',    idx: 2 },\n    { cls: 'klaizo-reviews', idx: 3 },\n    { cls: 'klaizo-faq',     idx: 4 }\n  ];\n\n  var navLinks = document.querySelectorAll('.kzh-nav a');\n\n  window.addEventListener('scroll', function(){\n    var scrollY = window.pageYOffset;\n    var active  = -1;\n\n    scrollTargets.forEach(function(t){\n      var el = document.querySelector('.' + t.cls);\n      if(!el) return;\n      var top = el.getBoundingClientRect().top + window.pageYOffset - HEADER_H - 40;\n      if(scrollY >= top) active = t.idx;\n    });\n\n    navLinks.forEach(function(a){ a.classList.remove('kzh-active'); });\n\n    if(active === -1){\n      navLinks[0] && navLinks[0].classList.add('kzh-active');\n    } else {\n      navLinks[active] && navLinks[active].classList.add('kzh-active');\n    }\n\n  }, { passive: true });\n\n})();\n</script>",
