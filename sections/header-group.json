        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_x3Q9PP": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .klaizo-footer {\n    background: #0d0d0d;\n    font-family: 'Barlow', sans-serif;\n    box-sizing: border-box;\n    border-top: 1px solid #1e1e1e;\n  }\n  .klaizo-footer * { box-sizing: border-box; }\n\n  /* MAIN */\n  .klaizo-footer__main {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 60px 40px 48px;\n    display: grid;\n    grid-template-columns: 1.8fr 1fr 1fr;\n    gap: 48px;\n  }\n\n  /* LOGO + DESC */\n  .klaizo-footer__logo {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-bottom: 18px;\n    text-decoration: none;\n  }\n\n  .klaizo-footer__logo-k {\n    color: #e8392a;\n    font-family: 'Bebas Neue', sans-serif;\n    font-size: 28px;\n    line-height: 1;\n  }\n\n  .klaizo-footer__logo-name {\n    color: #ffffff;\n    font-family: 'Bebas Neue', sans-serif;\n    font-size: 28px;\n    letter-spacing: 3px;\n    line-height: 1;\n  }\n\n  .klaizo-footer__desc {\n    color: rgba(255,255,255,0.42);\n    font-size: 14px;\n    line-height: 1.65;\n    margin: 0 0 24px;\n    max-width: 320px;\n  }\n\n  .klaizo-footer__socials {\n    display: flex;\n    gap: 12px;\n  }\n\n  .klaizo-footer__social-link {\n    width: 36px;\n    height: 36px;\n    border-radius: 8px;\n    border: 1px solid #2a2a2a;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: border-color 0.2s, background 0.2s;\n    text-decoration: none;\n  }\n\n  .klaizo-footer__social-link:hover {\n    border-color: #e8392a;\n    background: rgba(232,57,42,0.1);\n  }\n\n  .klaizo-footer__social-link svg {\n    width: 16px;\n    height: 16px;\n    fill: rgba(255,255,255,0.5);\n    transition: fill 0.2s;\n  }\n\n  .klaizo-footer__social-link:hover svg {\n    fill: #e8392a;\n  }\n\n  /* COLUMNAS LINKS */\n  .klaizo-footer__col-title {\n    color: #ffffff;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    margin: 0 0 20px;\n  }\n\n  .klaizo-footer__col-links {\n    list-style: none;\n    margin: 0;\n    padding: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n  }\n\n  .klaizo-footer__col-links a {\n    color: rgba(255,255,255,0.45);\n    font-size: 14px;\n    text-decoration: none;\n    transition: color 0.2s;\n  }\n\n  .klaizo-footer__col-links a:hover {\n    color: #ffffff;\n  }\n\n  /* BARRA MEDIA */\n  .klaizo-footer__bar {\n    border-top: 1px solid #1e1e1e;\n    border-bottom: 1px solid #1e1e1e;\n  }\n\n  .klaizo-footer__bar-inner {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 18px 40px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    gap: 20px;\n    flex-wrap: wrap;\n  }\n\n  .klaizo-footer__bar-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    color: rgba(255,255,255,0.5);\n    font-size: 13px;\n  }\n\n  .klaizo-footer__bar-item svg {\n    width: 18px;\n    height: 18px;\n    flex-shrink: 0;\n  }\n\n  /* BOTTOM */\n  .klaizo-footer__bottom {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 20px 40px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    flex-wrap: wrap;\n    gap: 12px;\n  }\n\n  .klaizo-footer__copy {\n    color: rgba(255,255,255,0.25);\n    font-size: 12px;\n    margin: 0;\n  }\n\n  .klaizo-footer__made {\n    color: rgba(255,255,255,0.25);\n    font-size: 12px;\n    margin: 0;\n  }\n\n  .klaizo-footer__made em {\n    font-style: italic;\n    color: rgba(255,255,255,0.35);\n  }\n\n  @media (max-width: 768px) {\n    .klaizo-footer__main {\n      grid-template-columns: 1fr;\n      padding: 48px 24px 36px;\n      gap: 36px;\n    }\n    .klaizo-footer__bar-inner {\n      flex-direction: column;\n      align-items: flex-start;\n      padding: 20px 24px;\n    }\n    .klaizo-footer__bottom {\n      padding: 16px 24px;\n      flex-direction: column;\n      align-items: flex-start;\n    }\n  }\n</style>\n\n<footer class=\"klaizo-footer\">\n\n  <!-- MAIN GRID -->\n  <div class=\"klaizo-footer__main\">\n\n    <!-- Columna marca -->\n    <div>\n      <a href=\"/\" class=\"klaizo-footer__logo\">\n        <span class=\"klaizo-footer__logo-k\">K</span>\n        <span class=\"klaizo-footer__logo-name\">KLAIZO</span>\n      </a>\n      <p class=\"klaizo-footer__desc\">Diseñado para situaciones reales. Tu respaldo cuando más lo necesitas, en cualquier carretera de Chile.</p>\n      <div class=\"klaizo-footer__socials\">\n        <!-- Email -->\n        <a href=\"mailto:contacto@klaizo.com\" class=\"klaizo-footer__social-link\" aria-label=\"Email\">\n          <svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z\"/>\n          </svg>\n        </a>\n        <!-- Instagram -->\n        <a href=\"https://instagram.com/klaizo\" target=\"_blank\" class=\"klaizo-footer__social-link\" aria-label=\"Instagram\">\n          <svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.334 3.608 1.308.975.975 1.246 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.334 2.633-1.308 3.608-.975.975-2.242 1.246-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.334-3.608-1.308-.975-.975-1.246-2.242-1.308-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.334-2.633 1.308-3.608.975-.975 2.242-1.246 3.608-1.308C8.416 2.175 8.796 2.163 12 2.163zm0-2.163C8.741 0 8.332.014 7.052.072 5.197.157 3.355.673 2.014 2.014.673 3.355.157 5.197.072 7.052.014 8.332 0 8.741 0 12c0 3.259.014 3.668.072 4.948.085 1.855.601 3.697 1.942 5.038 1.341 1.341 3.183 1.857 5.038 1.942C8