        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<style>\n.kzh *, .kzh *::before, .kzh *::after { box-sizing: border-box; margin: 0; padding: 0; }\n.kzh {\n  --red: #E8001D;\n  --black: #0d0d0d;\n  --light: #d0d0d0;\n  --white: #ffffff;\n  --gray: #9a9a9a;\n  --font: 'Inter', sans-serif;\n}\n\n.kzh-header {\n  position: fixed;\n  top: 0; left: 0; right: 0;\n  z-index: 9999;\n  height: 64px;\n  display: flex;\n  align-items: center;\n  background: rgba(13,13,13,0.93);\n  backdrop-filter: blur(14px);\n  -webkit-backdrop-filter: blur(14px);\n  border-bottom: 1px solid rgba(255,255,255,0.07);\n  font-family: var(--font);\n}\n\n.kzh-inner {\n  width: 100%;\n  max-width: 1280px;\n  margin: 0 auto;\n  padding: 0 28px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n}\n\n.kzh-logo img {\n  height: 34px;\n  width: auto;\n  display: block;\n  object-fit: contain;\n}\n\n.kzh-nav {\n  display: flex;\n  align-items: center;\n  gap: 2px;\n}\n.kzh-nav a {\n  color: var(--light);\n  text-decoration: none;\n  font-size: 13px;\n  font-weight: 500;\n  padding: 8px 13px;\n  border-radius: 100px;\n  transition: color 0.2s, background 0.2s;\n  white-space: nowrap;\n}\n.kzh-nav a:hover, .kzh-nav a.active {\n  color: var(--white);\n  background: rgba(255,255,255,0.09);\n}\n\n.kzh-right {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.kzh-btn-buy {\n  display: inline-flex;\n  align-items: center;\n  gap: 7px;\n  background: var(--red);\n  color: #fff;\n  font-family: var(--font);\n  font-size: 13px;\n  font-weight: 700;\n  padding: 9px 20px;\n  border-radius: 100px;\n  text-decoration: none;\n  transition: background 0.2s, box-shadow 0.2s, transform 0.15s;\n  white-space: nowrap;\n}\n.kzh-btn-buy:hover {\n  background: #ff1a35;\n  box-shadow: 0 4px 20px rgba(232,0,29,0.45);\n  transform: translateY(-1px);\n}\n\n.kzh-cart {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 38px; height: 38px;\n  border-radius: 50%;\n  background: rgba(255,255,255,0.06);\n  border: 1px solid rgba(255,255,255,0.1);\n  color: var(--light);\n  text-decoration: none;\n  transition: background 0.2s;\n}\n.kzh-cart:hover { background: rgba(255,255,255,0.13); color: #fff; }\n.kzh-cart svg { width: 18px; height: 18px; }\n\n.kzh-hamburger {\n  display: none;\n  flex-direction: column;\n  gap: 5px;\n  justify-content: center;\n  width: 36px; height: 36px;\n  background: none;\n  border: none;\n  cursor: pointer;\n  padding: 4px;\n}\n.kzh-hamburger span {\n  display: block;\n  width: 22px; height: 2px;\n  background: #fff;\n  border-radius: 2px;\n  transition: transform 0.3s, opacity 0.3s;\n  transform-origin: center;\n}\n.kzh-hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }\n.kzh-hamburger.open span:nth-child(2) { opacity: 0; }\n.kzh-hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }\n\n.kzh-mobile-nav {\n  display: none;\n  position: fixed;\n  top: 64px; left: 0; right: 0;\n  z-index: 9998;\n  background: rgba(13,13,13,0.97);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border-bottom: 1px solid rgba(255,255,255,0.08);\n  padding: 12px 24px 24px;\n  flex-direction: column;\n  opacity: 0;\n  transform: translateY(-8px);\n  transition: opacity 0.3s, transform 0.3s;\n}\n.kzh-mobile-nav.open { opacity: 1; transform: translateY(0); }\n.kzh-mobile-nav a {\n  color: var(--light);\n  text-decoration: none;\n  font-family: var(--font);\n  font-size: 15px;\n  font-weight: 500;\n  padding: 14px 0;\n  border-bottom: 1px solid rgba(255,255,255,0.06);\n  display: block;\n  transition: color 0.2s;\n}\n.kzh-mobile-nav a:hover { color: #fff; }\n.kzh-mobile-nav .kzh-mobile-buy {\n  margin-top: 16px;\n  display: block;\n  background: var(--red);\n  