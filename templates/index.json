      "settings": {
        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .klaizo-cta {\n    background: #111111;\n    padding: 90px 20px;\n    font-family: 'Barlow', sans-serif;\n    text-align: center;\n    box-sizing: border-box;\n    position: relative;\n    overflow: hidden;\n  }\n  .klaizo-cta * { box-sizing: border-box; }\n\n  /* Glow rojo de fondo */\n  .klaizo-cta::before {\n    content: '';\n    position: absolute;\n    top: 30%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 600px;\n    height: 400px;\n    background: radial-gradient(ellipse, rgba(232,57,42,0.18) 0%, transparent 70%);\n    pointer-events: none;\n  }\n\n  .klaizo-cta__badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 7px;\n    background: rgba(232,57,42,0.15);\n    border: 1px solid rgba(232,57,42,0.4);\n    border-radius: 999px;\n    color: #e8392a;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    padding: 7px 18px;\n    margin-bottom: 28px;\n  }\n\n  .klaizo-cta__heading {\n    font-family: 'Bebas Neue', sans-serif;\n    font-size: clamp(44px, 7vw, 82px);\n    line-height: 1.02;\n    color: #ffffff;\n    margin: 0 auto 36px;\n    max-width: 820px;\n  }\n\n  .klaizo-cta__price-box {\n    display: inline-flex;\n    align-items: center;\n    gap: 16px;\n    background: #1c1c1c;\n    border: 1px solid #2e2e2e;\n    border-radius: 14px;\n    padding: 20px 32px;\n    margin-bottom: 28px;\n  }\n\n  .klaizo-cta__price-inner {\n    text-align: left;\n  }\n\n  .klaizo-cta__price-before {\n    color: rgba(255,255,255,0.4);\n    font-size: 13px;\n    text-decoration: line-through;\n    margin: 0 0 3px;\n  }\n\n  .klaizo-cta__price-now {\n    color: #ffffff;\n    font-size: 32px;\n    font-weight: 700;\n    margin: 0;\n    line-height: 1;\n  }\n\n  .klaizo-cta__discount {\n    background: #e8392a;\n    color: #ffffff;\n    font-size: 13px;\n    font-weight: 700;\n    border-radius: 999px;\n    padding: 5px 12px;\n    white-space: nowrap;\n  }\n\n  .klaizo-cta__perks {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 28px;\n    color: rgba(255,255,255,0.55);\n    font-size: 14px;\n    margin-bottom: 40px;\n    flex-wrap: wrap;\n  }\n\n  .klaizo-cta__perks span {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n\n  .klaizo-cta__perks span::before {\n    font-size: 16px;\n  }\n\n  /* BOTÓN */\n  .klaizo-cta__btn {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    gap: 10px;\n    background: #e8392a;\n    color: #ffffff;\n    font-family: 'Barlow', sans-serif;\n    font-size: 17px;\n    font-weight: 700;\n    text-decoration: none;\n    border: none;\n    border-radius: 999px;\n    padding: 18px 48px;\n    cursor: pointer;\n    position: relative;\n    overflow: hidden;\n    animation: btnPulse 2.4s ease-in-out infinite;\n    transition: transform 0.15s ease, background 0.2s ease;\n  }\n\n  .klaizo-cta__btn::after {\n    content: '';\n    position: absolute;\n    top: 50%;\n    left: -60%;\n    transform: translateY(-50%) skewX(-20deg);\n    width: 40px;\n    height: 200%;\n    background: rgba(255,255,255,0.18);\n    animation: btnShine 2.4s ease-in-out infinite;\n  }\n\n  @keyframes btnPulse {\n    0%, 100% { box-shadow: 0 0 0 0 rgba(232,57,42,0.5); }\n    50%       { box-shadow: 0 0 0 12px rgba(232,57,42,0); }\n  }\n\n  @keyframes btnShine {\n    0%   { left: -60%; }\n    60%  { left: 130%; }\n    100% { left: 130%; }\n  }\n\n  .klaizo-cta__btn:hover {\n    background: #c72d1f;\n    transform: scale(1.04);\n    animation: none;\n    box-shadow: 0 8px 32px rgba(232,57,42,0.45);\n  }\n\n  .klaizo-cta__btn:active {\n    transform: scale(0.97);\n  }\n</style>\n\n<section class=\"klaizo-cta\">\n\n  <div class=\"klaizo-cta__badge\">\n    🔥 Oferta por tiempo limitado\n  </div>\n\n  <h2 class=\"klaizo-cta__heading\">\n    No esperes quedarte<br>botado para darte cuenta<br>que lo necesitabas.\n  </h2>\n\n  <div>\n    <div class=\"klaizo-cta__price-box\">\n      <div class=\"klaizo-cta__price-inner\">\n        <p class=\"klaizo-cta__price-before\">Antes $159.990</p>\n        <p class=\"klaizo-cta__price-now\">Hoy $99.990</p>\n      </div>\n      <span class=\"klaizo-cta__discount\">-38%</span>\n    </div>\n  </div>\n\n  <div class=\"klaizo-cta__perks\">\n    <span>📦 Envío gratis</span>\n    <span>🛡️ Garantía 30 días</span>\n    <span>⚡ Stock limitado</span>\n  </div>\n\n  <a href=\"https://klaizo.com/products/partidor-bateria-auto-compresor-multifun\" class=\"klaizo-cta__btn\">\n    ⚡ Comprar ahora\n  </a>\n\n</section>",
