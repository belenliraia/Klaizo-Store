      "settings": {
        "custom_liquid": "<style>\n.kzr *, .kzr *::before, .kzr *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n.kzr-section {\n  background: #0d0d0d;\n  padding: 90px 28px;\n  font-family: 'Inter', sans-serif;\n  overflow: hidden;\n}\n\n.kzr-inner {\n  max-width: 1200px;\n  margin: 0 auto;\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 72px;\n  align-items: center;\n}\n\n/* ── TEXTO ── */\n.kzr-tag {\n  font-size: 11px;\n  font-weight: 700;\n  letter-spacing: 0.18em;\n  text-transform: uppercase;\n  color: #E8001D;\n  margin-bottom: 20px;\n}\n\n.kzr-h2 {\n  font-size: clamp(34px, 4vw, 58px);\n  font-weight: 900;\n  line-height: 1.07;\n  color: #ffffff;\n  letter-spacing: -0.02em;\n  margin-bottom: 20px;\n}\n\n.kzr-body {\n  font-size: 15px;\n  color: #888;\n  line-height: 1.75;\n  margin-bottom: 32px;\n  max-width: 420px;\n}\n\n/* Lista checks */\n.kzr-list {\n  display: flex;\n  flex-direction: column;\n  gap: 14px;\n  margin-bottom: 40px;\n}\n.kzr-item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  font-size: 14px;\n  font-weight: 500;\n  color: #cccccc;\n}\n.kzr-check {\n  width: 22px; height: 22px;\n  flex-shrink: 0;\n  background: rgba(232,0,29,0.15);\n  border: 1px solid rgba(232,0,29,0.3);\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n.kzr-check svg { width: 11px; height: 11px; color: #E8001D; }\n\n/* Botón */\n.kzr-btn {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  background: #E8001D;\n  color: #fff;\n  font-family: 'Inter', sans-serif;\n  font-size: 15px;\n  font-weight: 700;\n  padding: 16px 36px;\n  border-radius: 100px;\n  text-decoration: none;\n  transition: background 0.2s, box-shadow 0.25s, transform 0.15s;\n}\n.kzr-btn:hover {\n  background: #ff1a35;\n  box-shadow: 0 6px 32px rgba(232,0,29,0.5);\n  transform: translateY(-2px);\n}\n.kzr-btn svg { width: 17px; height: 17px; }\n\n/* ── IMAGEN ── */\n.kzr-visual {\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n/* Glow de fondo */\n.kzr-glow {\n  position: absolute;\n  inset: -10%;\n  background: radial-gradient(ellipse at 50% 50%, rgba(232,0,29,0.2) 0%, transparent 65%);\n  filter: blur(30px);\n  pointer-events: none;\n  z-index: 0;\n  animation: kzrGlowPulse 3s ease-in-out infinite;\n}\n\n@keyframes kzrGlowPulse {\n  0%,100% { opacity: 0.7; transform: scale(1); }\n  50%     { opacity: 1;   transform: scale(1.06); }\n}\n\n/* Marco decorativo */\n.kzr-frame {\n  position: relative;\n  z-index: 2;\n  border-radius: 16px;\n  overflow: hidden;\n  box-shadow:\n    0 0 0 1px rgba(232,0,29,0.2),\n    0 24px 80px rgba(0,0,0,0.7),\n    0 0 60px rgba(232,0,29,0.08);\n  animation: kzrFloat 4s ease-in-out infinite;\n  width: 100%;\n  max-width: 560px;\n}\n\n@keyframes kzrFloat {\n  0%,100% { transform: translateY(0px) rotate(0deg); }\n  33%     { transform: translateY(-8px) rotate(0.3deg); }\n  66%     { transform: translateY(-4px) rotate(-0.2deg); }\n}\n\n.kzr-img {\n  width: 100%;\n  height: auto;\n  display: block;\n  transition: transform 5s ease;\n}\n.kzr-frame:hover .kzr-img { transform: scale(1.04); }\n\n/* Badges sobre imagen */\n.kzr-badges {\n  position: absolute;\n  bottom: -16px;\n  left: 50%;\n  transform: translateX(-50%);\n  display: flex;\n  gap: 10px;\n  z-index: 5;\n  white-space: nowrap;\n}\n.kzr-badge {\n  background: rgba(13,13,13,0.92);\n  border: 1px solid rgba(232,0,29,0.25);\n  backdrop-filter: blur(10px);\n  -webkit-backdrop-filter: blur(10px);\n  border-radius: 100px;\n  padding: 8px 16px;\n  display: flex;\n  align-items: center;\n  gap: 7px;\n  font-size: 11px;\n  font-weight: 600;\n  color: #fff;\n  font-family: 'Inter', sans-serif;\n  box-shadow: 0 4px 20px rgba(0,0,0,0.5);\n}\n.kzr-badge svg { width: 13px; height: 13px; color: #E8001D; flex-shrink: 0; }\n\n/* Scroll reveal */\n.kzr-reveal-left {\n  opacity: 0; transform: translateX(-32px);\n  transition: opacity 0.8s ease, transform 0.8s ease;\n}\n.kzr-reveal-right {\n  opacity: 0; transform: translateX(32px);\n  transition: opacity 0.8s ease, transform 0.8s ease;\n}\n.kzr-reveal-left.kzr-vis,\n.kzr-reveal-right.kzr-vis {\n  opacity: 1; transform: translateX(0);\n}\n\n/* ── RESPONSIVE ── */\n@media (max-width: 960px) {\n  .kzr-inner { grid-template-columns: 1fr; gap: 56px; }\n  .kzr-body { max-width: 100%; }\n  .kzr-frame { max-width: 480px; margin: 0 auto; }\n  .kzr-badges { bottom: -14px; }\n  .kzr-section { padding: 72px 24px 80px; }\n}\n@media (max-width: 640px) {\n  .kzr-section { padding: 60px 20px 72px; }\n  .kzr-h2 { font-size: clamp(30px, 9vw, 44px); }\n  .kzr-frame { max-width: 100%; }\n  .kzr-badges { gap: 6px; bottom: -12px; }\n  .kzr-badge { font-size: 10px; padding: 7px 12px; }\n  .kzr-btn { width: 100%; justify-content: center; font-size: 16px; padding: 17px; border-radius: 12px; }\n}\n@media (max-width: 400px) {\n  .kzr-badges { flex-direction: column; align-items: center; bottom: -52px; }\n}\n</style>\n\n<div class=\"kzr\">\n  <section class=\"kzr-section\">\n    <div class=\"kzr-inner\">\n\n      <!-- TEXTO izquierda -->\n      <div class=\"kzr-text kzr-reveal-left\">\n        <div class=\"kzr-tag\">Tu respaldo</div>\n\n        <h2 class=\"kzr-h2\">Tu respaldo cuando<br>más lo necesitas.</h2>\n\n        <p class=\"kzr-body\">\n          Diseñado para ayudarte en situaciones reales: batería descargada, neumáticos bajos y emergencias nocturnas.\n        </p>\n\n        <div class=\"kzr-list\">\n          <div class=\"kzr-item\">\n            <div class=\"kzr-check\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n            </div>\n            Arranca tu auto en minutos\n          </div>\n          <div class=\"kzr-item\">\n            <div class=\"kzr-check\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n            </div>\n            Infla neumáticos en carretera\n          </div>\n          <div class=\"kzr-item\">\n            <div class=\"kzr-check\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n            </div>\n            Ilumina zonas oscuras\n          </div>\n          <div class=\"kzr-item\">\n            <div class=\"kzr-check\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n            </div>\n            Compacto y fácil de guardar\n          </div>\n        </div>\n\n        <a href=\"https://klaizo.com/products/partidor-bateria-auto-compresor-multifun\" class=\"kzr-btn\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <circle cx=\"9\" cy=\"21\" r=\"1\"/><circle cx=\"20\" cy=\"21\" r=\"1\"/>\n            <path d=\"M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6\"/>\n          </svg>\n          Comprar ahora\n        </a>\n      </div>\n\n      <!-- IMAGEN derecha -->\n      <div class=\"kzr-visual kzr-reveal-right\">\n        <div class=\"kzr-glow\"></div>\n        <div class=\"kzr-frame\">\n          <img\n            class=\"kzr-img\"\n            src=\"https://cdn.shopify.com/s/files/1/0796/2581/4243/files/ChatGPT_Image_2_may_2026_05_04_54_p.m..png?v=1777755912\"\n            alt=\"KLAIZO PowerGo — Arranca tu auto en segundos\"\n            loading=\"lazy\"\n          >\n        </div>\n        <div class=\"kzr-badges\">\n          <div class=\"kzr-badge\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"/></svg>\n            Arranque potente\n          </div>\n          <div class=\"kzr-badge\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n            Seguro y confiable\n          </div>\n          <div class=\"kzr-badge\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><rect x=\"2\" y=\"7\" width=\"20\" height=\"14\" rx=\"2\"/><path d=\"M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2\"/></svg>\n            Compacto y portátil\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </section>\n</div>\n\n<script>\n(function(){\n  var els = document.querySelectorAll('.kzr-reveal-left, .kzr-reveal-right');\n  if(!els.length) return;\n  var obs = new IntersectionObserver(function(entries){\n    entries.forEach(function(e){\n      if(e.isIntersecting){\n        e.target.classList.add('kzr-vis');\n        obs.unobserve(e.target);\n      }\n    });\n  }, { threshold: 0.15 });\n  els.forEach(function(el){ obs.observe(el); });\n})();\n</script>",
