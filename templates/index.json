        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .klaizo-demo {\n    background: #111111;\n    padding: 80px 40px;\n    font-family: 'Barlow', sans-serif;\n    box-sizing: border-box;\n  }\n  .klaizo-demo * { box-sizing: border-box; }\n\n  .klaizo-demo__label {\n    color: #e8392a;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    text-align: center;\n    margin: 0 0 16px;\n  }\n\n  .klaizo-demo__heading {\n    font-family: 'Bebas Neue', sans-serif;\n    font-size: clamp(40px, 5.5vw, 70px);\n    line-height: 1.05;\n    color: #ffffff;\n    text-align: center;\n    margin: 0 auto 52px;\n    max-width: 720px;\n  }\n\n  .klaizo-demo__grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 12px;\n    max-width: 1300px;\n    margin: 0 auto;\n  }\n\n  .klaizo-demo__card {\n    border-radius: 12px;\n    overflow: hidden;\n    position: relative;\n    aspect-ratio: 3 / 4;\n    display: block;\n    text-decoration: none;\n  }\n\n  .klaizo-demo__card img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    transition: transform 0.5s ease;\n  }\n\n  .klaizo-demo__card:hover img {\n    transform: scale(1.05);\n  }\n\n  .klaizo-demo__card-overlay {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    background: linear-gradient(0deg, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.25) 60%, transparent 100%);\n    padding: 28px 20px 24px;\n  }\n\n  .klaizo-demo__card-title {\n    color: #ffffff;\n    font-size: 17px;\n    font-weight: 700;\n    margin: 0 0 6px;\n    line-height: 1.2;\n  }\n\n  .klaizo-demo__card-desc {\n    color: rgba(255, 255, 255, 0.72);\n    font-size: 13px;\n    margin: 0;\n    line-height: 1.45;\n  }\n\n  @media (max-width: 768px) {\n    .klaizo-demo {\n      padding: 60px 20px;\n    }\n    .klaizo-demo__grid {\n      grid-template-columns: repeat(2, 1fr);\n      gap: 10px;\n    }\n  }\n\n  @media (max-width: 480px) {\n    .klaizo-demo__card-title { font-size: 14px; }\n    .klaizo-demo__card-desc { font-size: 12px; }\n  }\n</style>\n\n<section class=\"klaizo-demo\">\n  <p class=\"klaizo-demo__label\">Demostración</p>\n  <h2 class=\"klaizo-demo__heading\">Imagina tenerlo cuando más lo necesites.</h2>\n\n  <div class=\"klaizo-demo__grid\">\n\n    <a href=\"/products/partidor-bateria-auto-compresor-multifun\" class=\"klaizo-demo__card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0796/2581/4243/files/ChatGPT_Image_1_may_2026_07_57_48_p.m..png?v=1777738732\" alt=\"Batería descargada\" loading=\"lazy\">\n      <div class=\"klaizo-demo__card-overlay\">\n        <p class=\"klaizo-demo__card-title\">Batería descargada</p>\n        <p class=\"klaizo-demo__card-desc\">Arranca tu auto sin depender de nadie.</p>\n      </div>\n    </a>\n\n    <a href=\"/products/partidor-bateria-auto-compresor-multifun\" class=\"klaizo-demo__card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0796/2581/4243/files/ChatGPT_Image_1_may_2026_07_50_08_p.m..png?v=1777738732\" alt=\"Inflando neumáticos\" loading=\"lazy\">\n      <div class=\"klaizo-demo__card-overlay\">\n        <p class=\"klaizo-demo__card-title\">Inflando neumáticos</p>\n        <p class=\"klaizo-demo__card-desc\">Compresor preciso para cualquier presión.</p>\n      </div>\n    </a>\n\n    <a href=\"/products/partidor-bateria-auto-compresor-multifun\" class=\"klaizo-demo__card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0796/2581/4243/files/ChatGPT_Image_2_may_2026_05_10_39_p.m..png?v=1777756487\" alt=\"Linterna LED\" loading=\"lazy\">\n      <div class=\"klaizo-demo__card-overlay\">\n        <p class=\"klaizo-demo__card-title\">Linterna LED</p>\n        <p class=\"klaizo-demo__card-desc\">Visibilidad total en emergencias nocturnas.</p>\n      </div