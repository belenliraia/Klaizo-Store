        "custom_liquid": "<style>\n.kzp *, .kzp *::before, .kzp *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n.kzp-section {\n  background: #0d0d0d;\n  padding: 80px 28px;\n  font-family: 'Inter', sans-serif;\n  overflow: hidden;\n}\n\n.kzp-inner {\n  max-width: 1200px;\n  margin: 0 auto;\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 64px;\n  align-items: center;\n}\n\n/* ── IMAGEN ── */\n.kzp-img-col { position: relative; }\n\n.kzp-img-wrap {\n  position: relative;\n  border-radius: 4px;\n  overflow: hidden;\n  line-height: 0;\n}\n\n.kzp-img {\n  width: 100%;\n  height: 480px;\n  object-fit: cover;\n  object-position: center top;\n  display: block;\n  filter: brightness(0.85);\n  transition: transform 6s ease;\n}\n.kzp-img-wrap:hover .kzp-img { transform: scale(1.03); }\n\n/* Caption debajo de imagen */\n.kzp-caption {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  margin-top: 16px;\n  padding-left: 4px;\n}\n.kzp-caption-line {\n  width: 32px;\n  height: 2px;\n  background: #E8001D;\n  flex-shrink: 0;\n}\n.kzp-caption-text {\n  font-size: 12px;\n  color: #666;\n  font-style: italic;\n  letter-spacing: 0.02em;\n}\n\n/* ── TEXTO ── */\n.kzp-text-col {\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n}\n\n.kzp-tag {\n  font-size: 11px;\n  font-weight: 700;\n  letter-spacing: 0.16em;\n  text-transform: uppercase;\n  color: #E8001D;\n  margin-bottom: 20px;\n}\n\n.kzp-h2 {\n  font-size: clamp(36px, 4.5vw, 64px);\n  font-weight: 900;\n  line-height: 1.05;\n  color: #ffffff;\n  letter-spacing: -0.02em;\n  margin-bottom: 24px;\n}\n.kzp-h2 em {\n  font-style: normal;\n  color: #E8001D;\n}\n\n.kzp-body {\n  font-size: 15px;\n  color: #a0a0a0;\n  line-height: 1.75;\n  margin-bottom: 36px;\n  max-width: 440px;\n}\n.kzp-body strong { color: #d0d0d0; font-weight: 600; }\n\n/* Lista de puntos */\n.kzp-list {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n  margin-bottom: 40px;\n}\n.kzp-list-item {\n  display: flex;\n  align-items: flex-start;\n  gap: 12px;\n  font-size: 14px;\n  color: #b0b0b0;\n  line-height: 1.5;\n}\n.kzp-list-icon {\n  width: 20px;\n  height: 20px;\n  flex-shrink: 0;\n  background: rgba(232,0,29,0.12);\n  border: 1px solid rgba(232,0,29,0.25);\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-top: 1px;\n}\n.kzp-list-icon svg { width: 10px; height: 10px; color: #E8001D; }\n\n/* CTA link */\n.kzp-link {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  color: #ffffff;\n  text-decoration: none;\n  font-size: 14px;\n  font-weight: 700;\n  letter-spacing: 0.04em;\n  padding-bottom: 4px;\n  border-bottom: 1px solid rgba(255,255,255,0.25);\n  transition: color 0.2s, border-color 0.2s, gap 0.2s;\n  align-self: flex-start;\n}\n.kzp-link:hover {\n  color: #E8001D;\n  border-color: #E8001D;\n  gap: 14px;\n}\n.kzp-link svg { width: 16px; height: 16px; transition: transform 0.2s; }\n.kzp-link:hover svg { transform: translateX(3px); }\n\n/* Scroll reveal */\n.kzp-reveal {\n  opacity: 0;\n  transform: translateY(28px);\n  transition: opacity 0.75s ease, transform 0.75s ease;\n}\n.kzp-reveal.kzp-visible {\n  opacity: 1;\n  transform: translateY(0);\n}\n.kzp-reveal-img {\n  opacity: 0;\n  transform: translateX(-28px);\n  transition: opacity 0.75s ease, transform 0.75s ease;\n}\n.kzp-reveal-img.kzp-visible {\n  opacity: 1;\n  transform: translateX(0);\n}\n\n/* ── RESPONSIVE ── */\n@media (max-width: 900px) {\n  .kzp-inner {\n    grid-template-columns: 1fr;\n    gap: 40px;\n  }\n  .kzp-img { height: 380px; }\n  .kzp-body { max-width: 100%; }\n  .kzp-section { padding: 64px 24px; }\n}\n@media (max-width: 640px) {\n  .kzp-section { padding: 56px 20px; }\n  .kzp-img { height: 280px; object-position: center 20%; }\n  .kzp-h2 { font-size: clamp(32px, 9vw, 48px); }\n}\n</style>\n\n<div class=\"kzp\">\n  <section class=\"kzp-section\">\n    <div class=\"kzp-inner\">\n\n      <!-- Imagen izquierda -->\n      <div class=\"kzp-img-col kzp-reveal-img\">\n        <div class=\"kzp-img-wrap\">\n          <img\n            class=\"kzp-img\"\n            src=\"https://cdn.shopify.com/s/files/1/0796/2581/4243/files/ChatGPT_Image_1_may_2026_07_47_49_p.m..png?v=1777738732\"\n            alt=\"Conductor varado con auto averiado\"\n            loading=\"lazy\"\n          >\n        </div>\n        <div class=\"kzp-caption\">\n          <div class=\"kzp-caption-line\"></div>\n          <span class=\"kzp-caption-text\">Una situación real. A muchos les ha pasado.</span>\n        </div>\n      </div>\n\n      <!-- Texto derecha -->\n      <div class=\"kzp-text-col kzp-reveal\">\n        <div class=\"kzp-tag\">El problema</div>\n\n        <h2 class=\"kzp-h2\">\n          Las emergencias<br><em>no avisan.</em>\n        </h2>\n\n        <p class=\"kzp-body\">\n          Una batería descargada o un neumático bajo pueden arruinar tu viaje en segundos.\n          <strong>KLAIZO PowerGo</strong> fue diseñado para darte control cuando más lo necesitas.\n        </p>\n\n        <div class=\"kzp-list\">\n          <div class=\"kzp-list-item\">\n            <div class=\"kzp-list-icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg>\n            </div>\n            Quedarte varado en carretera sin ayuda cerca\n          </div>\n          <div class=\"kzp-list-item\">\n            <div class=\"kzp-list-icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg>\n            </div>\n            Esperar horas una grúa con tu familia a bordo\n          </div>\n          <div class=\"kzp-list-item\">\n            <div class=\"kzp-list-icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg>\n            </div>\n            Depender de extraños para arrancar tu auto\n          </div>\n        </div>\n\n        <a href=\"https://klaizo.com/products/partidor-bateria-auto-compresor-multifun\" class=\"kzp-link\">\n          Descubrir KLAIZO\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <path d=\"M5 12h14M12 5l7 7-7 7\"/>\n          </svg>\n        </a>\n      </div>\n\n    </div>\n  </section>\n</div>\n\n<script>\n(function(){\n  var els = document.querySelectorAll('.kzp-reveal, .kzp-reveal-img');\n  if(!els.length) return;\n  var obs = new IntersectionObserver(function(entries){\n    entries.forEach(function(e){\n      if(e.isIntersecting){\n        e.target.classList.add('kzp-visible');\n        obs.unobserve(e.target);\n      }\n    });\n  }, { threshold: 0.15 });\n  els.forEach(function(el){ obs.observe(el); });\n})();\n</script>",
