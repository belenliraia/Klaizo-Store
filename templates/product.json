      "settings": {
        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .kpg { background: #111; font-family: 'Barlow', sans-serif; padding: 40px 40px 60px; box-sizing: border-box; }\n  .kpg * { box-sizing: border-box; }\n\n  .kpg__inner {\n    max-width: 1160px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 56px;\n    align-items: start;\n  }\n\n  .kpg__gallery { display: flex; flex-direction: column; gap: 12px; }\n\n  .kpg__main-img {\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    border-radius: 16px;\n    overflow: hidden;\n    background: #1a1a1a;\n  }\n\n  .kpg__main-img img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    transition: opacity 0.25s ease;\n  }\n\n  .kpg__thumbs {\n    display: flex;\n    gap: 8px;\n    flex-wrap: wrap;\n  }\n\n  .kpg__thumb {\n    width: 72px;\n    height: 72px;\n    border-radius: 10px;\n    overflow: hidden;\n    background: #1a1a1a;\n    cursor: pointer;\n    border: 2px solid transparent;\n    transition: border-color 0.2s;\n    flex-shrink: 0;\n  }\n\n  .kpg__thumb.is-active { border-color: #e8392a; }\n\n  .kpg__thumb img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  .kpg__info { padding-top: 4px; }\n\n  .kpg__badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    background: rgba(232,57,42,0.15);\n    border: 1px solid rgba(232,57,42,0.4);\n    border-radius: 999px;\n    color: #e8392a;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    padding: 5px 14px;\n    margin-bottom: 16px;\n  }\n\n  .kpg__title {\n    font-family: 'Bebas Neue', sans-serif;\n    font-size: clamp(36px, 4vw, 52px);\n    color: #fff;\n    margin: 0 0 8px;\n    line-height: 1.0;\n    letter-spacing: 1px;\n  }\n\n  .kpg__subtitle {\n    color: rgba(255,255,255,0.5);\n    font-size: 15px;\n    margin: 0 0 16px;\n  }\n\n  .kpg__stars {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-bottom: 20px;\n    font-size: 14px;\n    color: rgba(255,255,255,0.5);\n  }\n\n  .kpg__stars-icons { color: #e8392a; letter-spacing: 2px; font-size: 15px; }\n\n  .kpg__price-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 14px;\n  }\n\n  .kpg__price {\n    font-size: 38px;\n    font-weight: 700;\n    color: #fff;\n    line-height: 1;\n  }\n\n  .kpg__price-old {\n    font-size: 16px;\n    color: rgba(255,255,255,0.35);\n    text-decoration: line-through;\n  }\n\n  .kpg__discount {\n    background: #e8392a;\n    color: #fff;\n    font-size: 12px;\n    font-weight: 700;\n    border-radius: 999px;\n    padding: 4px 10px;\n  }\n\n  .kpg__perks {\n    display: flex;\n    gap: 18px;\n    flex-wrap: wrap;\n    margin-bottom: 22px;\n  }\n\n  .kpg__perk {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    color: rgba(255,255,255,0.5);\n    font-size: 13px;\n  }\n\n  .kpg__perk svg { width: 15px; height: 15px; flex-shrink: 0; }\n\n  .kpg__divider { border: none; border-top: 1px solid #222; margin: 0 0 20px; }\n\n  .kpg__features {\n    list-style: none;\n    margin: 0 0 24px;\n    padding: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 11px;\n  }\n\n  .kpg__features li {\n    display: flex;\n    align-items: flex-start;\n    gap: 10px;\n    color: rgba(255,255,255,0.75);\n    font-size: 14px;\n    line-height: 1.4;\n  }\n\n  .kpg__features li::before {\n    content: '';\n    width: 18px;\n    height: 18px;\n    flex-shrink: 0;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 18 18' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='9' cy='9' r='9' fill='%23e8392a' fill-opacity='0.15'/%3E%3Cpath d='M5 9l3 3 5-5' stroke='%23e8392a' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E\");\n    background-size: contain;\n    margin-top: 1px;\n  }\n\n  .kpg__buy-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 20px;\n  }\n\n  .kpg__qty {\n    display: flex;\n    align-items: center;\n    background: #1a1a1a;\n    border: 1px solid #2e2e2e;\n    border-radius: 999px;\n    overflow: hidden;\n  }\n\n  .kpg__qty-btn {\n    background: none;\n    border: none;\n    color: #fff;\n    font-size: 20px;\n    width: 40px;\n    height: 48px;\n    cursor: pointer;\n    line-height: 1;\n    transition: color 0.2s;\n  }\n\n  .kpg__qty-btn:hover { color: #e8392a; }\n\n  .kpg__qty-num {\n    color: #fff;\n    font-size: 15px;\n    font-weight: 600;\n    min-width: 28px;\n    text-align: center;\n  }\n\n  .kpg__btn {\n    flex: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    background: #e8392a;\n    color: #fff;\n    font-family: 'Barlow', sans-serif;\n    font-size: 17px;\n    font-weight: 700;\n    border: none;\n    border-radius: 999px;\n    padding: 14px 28px;\n    cursor: pointer;\n    position: relative;\n    overflow: hidden;\n    animation: kpgPulse 2.4s ease-in-out infinite;\n    transition: transform 0.15s, background 0.2s;\n  }\n\n  .kpg__btn::after {\n    content: '';\n    position: absolute;\n    top: 50%; left: -60%;\n    transform: translateY(-50%) skewX(-20deg);\n    width: 36px; height: 200%;\n    background: rgba(255,255,255,0.16);\n    animation: kpgShine 2.4s ease-in-out infinite;\n  }\n\n  @keyframes kpgPulse {\n    0%,100% { box-shadow: 0 0 0 0 rgba(232,57,42,0.5); }\n    50%      { box-shadow: 0 0 0 10px rgba(232,57,42,0); }\n  }\n\n  @keyframes kpgShine {\n    0%  { left: -60%; }\n    60% { left: 130%; }\n    100%{ left: 130%; }\n  }\n\n  .kpg__btn:hover { background: #c72d1f; transform: scale(1.03); animation: none; }\n  .kpg__btn:active { transform: scale(0.97); }\n\n  .kpg__btn:disabled {\n    background: #444;\n    animation: none;\n    cursor: not-allowed;\n    transform: none;\n  }\n\n  .kpg__feat-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 8px;\n  }\n\n  .kpg__feat-card {\n    background: #1a1a1a;\n    border: 1px solid #272727;\n    border-radius: 12px;\n    padding: 14px 10px;\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 6px;\n  }\n\n  .kpg__feat-card svg { width: 22px; height: 22px; color: #e8392a; }\n\n  .kpg__feat-title {\n    color: #fff;\n    font-size: 12px;\n    font-weight: 700;\n    margin: 0;\n  }\n\n  .kpg__feat-sub {\n    color: rgba(255,255,255,0.4);\n    font-size: 11px;\n    margin: 0;\n  }\n\n  @media (max-width: 860px) {\n    .kpg { padding: 24px 20px 48px; }\n    .kpg__inner { grid-template-columns: 1fr; gap: 32px; }\n    .kpg__feat-grid { grid-template-columns: repeat(2, 1fr); }\n  }\n</style>\n\n<div class=\"kpg\">\n  <div class=\"kpg__inner\">\n\n    <div class=\"kpg__gallery\">\n      <div class=\"kpg__main-img\">\n        <img id=\"kpgMainImg\" src=\"{{ product.featured_image | img_url: '800x800' }}\" alt=\"{{ product.title }}\">\n      </div>\n      <div class=\"kpg__thumbs\">\n        {% for image in product.images %}\n          <div class=\"kpg__thumb {% if forloop.first %}is-active{% endif %}\"\n               onclick=\"kpgSetImg(this, '{{ image | img_url: '800x800' }}')\">\n            <img src=\"{{ image | img_url: '150x150' }}\" alt=\"{{ product.title }} {{ forloop.index }}\">\n          </div>\n        {% endfor %}\n      </div>\n    </div>\n\n    <div class=\"kpg__info\">\n\n      <div class=\"kpg__badge\">🔥 Stock limitado</div>\n\n      <h1 class=\"kpg__title\">{{ product.title }}</h1>\n      <p class=\"kpg__subtitle\">El copiloto que puede salvarte en cualquier emergencia.</p>\n\n      <div class=\"kpg__stars\">\n        <span class=\"kpg__stars-icons\">★★★★★</span>\n        <span>4.9 · +3.000 conductores</span>\n      </div>\n\n      <div class=\"kpg__price-row\">\n        <span class=\"kpg__price\">{{ product.price | money }}</span>\n        {% if product.compare_at_price > product.price %}\n          <span class=\"kpg__price-old\">{{ product.compare_at_price | money }}</span>\n          <span class=\"kpg__discount\">-38%</span>\n        {% endif %}\n      </div>\n\n      <div class=\"kpg__perks\">\n        <span class=\"kpg__perk\">\n          <svg viewBox=\"0 0 24 24\" fill=\"#e8392a\"><path d=\"M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z\"/></svg>\n          Envío gratis\n        </span>\n        <span class=\"kpg__perk\">\n          <svg viewBox=\"0 0 24 24\" fill=\"#e8392a\"><path d=\"M12 1L3 5v6c0 5.25 3.75 10.15 9 11.35C17.25 21.15 21 16.25 21 11V5L12 1zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z\"/></svg>\n          Garantía oficial\n        </span>\n        <span class=\"kpg__perk\">\n          <svg viewBox=\"0 0 24 24\" fill=\"#e8392a\"><path d=\"M20 4H4c-1.11 0-2 .89-2 2v12c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z\"/></svg>\n          Pago seguro\n        </span>\n      </div>\n\n      <hr class=\"kpg__divider\">\n\n      <ul class=\"kpg__features\">\n        <li>Arranca vehículos en segundos (hasta 6.0L)</li>\n        <li>Compresor de aire integrado con presión digital</li>\n        <li>Linterna LED con modo SOS</li>\n        <li>Compatible con autos, motos y embarcaciones</li>\n        <li>Powerbank USB-C para celulares y notebooks</li>\n        <li>Compacto y portátil — cabe en la guantera</li>\n      </ul>\n\n      <div class=\"kpg__buy-row\">\n        <div class=\"kpg__qty\">\n          <button type=\"button\" class=\"kpg__qty-btn\" onclick=\"kpgQty(-1)\">−</button>\n          <span class=\"kpg__qty-num\" id=\"kpgQtyNum\">1</span>\n          <button type=\"button\" class=\"kpg__qty-btn\" onclick=\"kpgQty(1)\">+</button>\n        </div>\n        <button type=\"button\" class=\"kpg__btn\" id=\"kpgBuyBtn\" onclick=\"kpgComprar()\">\n          ⚡ Comprar ahora\n        </button>\n      </div>\n\n      <div class=\"kpg__feat-grid\">\n        <div class=\"kpg__feat-card\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M7 2v11h3v9l7-12h-4l4-8z\"/></svg>\n          <p class=\"kpg__feat-title\">Arranque</p>\n          <p class=\"kpg__feat-sub\">Hasta 2000A</p>\n        </div>\n        <div class=\"kpg__feat-card\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z\"/></svg>\n          <p class=\"kpg__feat-title\">Compresor</p>\n          <p class=\"kpg__feat-sub\">Presión digital</p>\n        </div>\n        <div class=\"kpg__feat-card\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z\"/></svg>\n          <p class=\"kpg__feat-title\">Linterna LED</p>\n          <p class=\"kpg__feat-sub\">Modo SOS</p>\n        </div>\n        <div class=\"kpg__feat-card\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.06 15.96 0 13.36 0c-1.31 0-2.5.54-3.36 1.42C9.14.54 7.95 0 6.64 0 4.04 0 2 2.06 2 4.64c0 .48.11.92.18 1.36H0v14h24V6h-4zM13.36 2c1.48 0 2.64 1.16 2.64 2.64 0 .48-.14.92-.36 1.36h-4.56c-.22-.44-.36-.88-.36-1.36C10.72 3.16 11.88 2 13.36 2zM4 4.64C4 3.16 5.16 2 6.64 2s2.64 1.16 2.64 2.64c0 .48-.14.92-.36 1.36H4.36C4.14 5.56 4 5.12 4 4.64zM2 8h9v10H2V8zm11 10V8h9v10h-9z\"/></svg>\n          <p class=\"kpg__feat-title\">Portátil</p>\n          <p class=\"kpg__feat-sub\">Estuche premium</p>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n  var kpgQtyVal = 1;\n  var kpgVariantId = {{ product.selected_or_first_available_variant.id }};\n\n  function kpgSetImg(thumb, url) {\n    document.getElementById('kpgMainImg').src = url;\n    document.querySelectorAll('.kpg__thumb').forEach(function(t) {\n      t.classList.remove('is-active');\n    });\n    thumb.classList.add('is-active');\n  }\n\n  function kpgQty(delta) {\n    kpgQtyVal = Math.max(1, kpgQtyVal + delta);\n    document.getElementById('kpgQtyNum').textContent = kpgQtyVal;\n  }\nasync function kpgComprar() {\n\n  var btn = document.getElementById('kpgBuyBtn');\n\n  btn.disabled = true;\n  btn.innerHTML = 'Agregando...';\n\n  try {\n\n    const response = await fetch('/cart/add.js', {\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json'\n      },\n      body: JSON.stringify({\n        items: [\n          {\n            id: kpgVariantId,\n            quantity: kpgQtyVal\n          }\n        ]\n      })\n    });\n\n    if (!response.ok) {\n\n      const errorData = await response.json();\n\n      throw new Error(\n        errorData.description ||\n        'Error al agregar el producto al carrito.'\n      );\n    }\n\n    window.location.href = '/cart';\n\n  } catch (error) {\n\n    alert(error.message);\n\n    btn.disabled = false;\n    btn.innerHTML = '⚡ Comprar ahora';\n  }\n}\n</script>",
