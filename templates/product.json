    "custom_liquid_VNnpwX": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n.klem * { box-sizing: border-box; margin: 0; padding: 0; }\n\n.klem-section {\n  background: #0a0a0a;\n  padding: 100px 24px 110px;\n  text-align: center;\n  font-family: 'Barlow', sans-serif;\n  position: relative;\n  overflow: hidden;\n}\n\n/* Fondo con glow central */\n.klem-section::before {\n  content: '';\n  position: absolute;\n  top: 50%; left: 50%;\n  transform: translate(-50%, -50%);\n  width: 700px; height: 400px;\n  background: radial-gradient(ellipse at center, rgba(232,57,42,0.12) 0%, transparent 65%);\n  pointer-events: none;\n  animation: klemGlow 4s ease-in-out infinite;\n}\n\n@keyframes klemGlow {\n  0%,100% { opacity: 0.7; transform: translate(-50%, -50%) scale(1); }\n  50%      { opacity: 1;   transform: translate(-50%, -50%) scale(1.08); }\n}\n\n/* Tag superior */\n.klem-tag {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  font-size: 11px;\n  font-weight: 700;\n  letter-spacing: 0.18em;\n  text-transform: uppercase;\n  color: #e8392a;\n  margin-bottom: 36px;\n  position: relative;\n}\n.klem-tag::before,\n.klem-tag::after {\n  content: '';\n  display: block;\n  width: 32px; height: 1px;\n  background: rgba(232,57,42,0.4);\n}\n\n/* Líneas de preguntas */\n.klem-questions {\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n  margin-bottom: 44px;\n  position: relative;\n}\n\n.klem-line {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: clamp(44px, 7vw, 86px);\n  line-height: 1.05;\n  color: #ffffff;\n  display: block;\n  cursor: default;\n  position: relative;\n  transition: color 0.25s ease, text-shadow 0.25s ease, transform 0.25s ease;\n\n  /* Entrada animada */\n  opacity: 0;\n  transform: translateY(28px);\n}\n\n.klem-line.klem-vis {\n  animation: klemUp 0.7s ease forwards;\n}\n.klem-line:nth-child(1) { animation-delay: 0.05s; }\n.klem-line:nth-child(2) { animation-delay: 0.18s; }\n.klem-line:nth-child(3) { animation-delay: 0.31s; }\n\n@keyframes klemUp {\n  to { opacity: 1; transform: translateY(0); }\n}\n\n/* Hover: texto rojo con glow */\n.klem-line:hover {\n  color: #e8392a;\n  text-shadow:\n    0 0 20px rgba(232,57,42,0.5),\n    0 0 60px rgba(232,57,42,0.2);\n  transform: scale(1.02);\n}\n\n/* Descripción */\n.klem-desc {\n  max-width: 580px;\n  margin: 0 auto;\n  font-size: 16px;\n  font-weight: 400;\n  color: #888;\n  line-height: 1.75;\n  position: relative;\n\n  opacity: 0;\n  transform: translateY(16px);\n  transition: opacity 0.7s ease, transform 0.7s ease;\n}\n.klem-desc.klem-vis {\n  opacity: 1;\n  transform: translateY(0);\n}\n.klem-desc strong { color: #ccc; font-weight: 600; }\n\n/* Separador decorativo */\n.klem-divider {\n  width: 48px; height: 2px;\n  background: linear-gradient(to right, transparent, #e8392a, transparent);\n  margin: 32px auto 0;\n  opacity: 0;\n  transition: opacity 0.7s 0.3s ease;\n}\n.klem-desc.klem-vis ~ .klem-divider,\n.klem-divider.klem-vis { opacity: 1; }\n\n/* Responsive */\n@media (max-width: 640px) {\n  .klem-section { padding: 72px 20px 80px; }\n  .klem-line { font-size: clamp(36px, 10vw, 56px); }\n  .klem-desc { font-size: 15px; }\n}\n</style>\n\n<div class=\"klem\">\n  <section class=\"klem-section\">\n\n    <div class=\"klem-tag\">\n      Diseñado para emergencias\n    </div>\n\n    <div class=\"klem-questions\">\n      <span class=\"klem-line\">¿Batería descargada?</span>\n      <span class=\"klem-line\">¿Neumático desinflado?</span>\n      <span class=\"klem-line\">¿Oscuridad total en carretera?</span>\n    </div>\n\n    <p class=\"klem-desc\">\n      KLAIZO PowerGo reúne las herramientas esenciales que todo conductor debería llevar siempre.\n      <strong>No dependas de terceros.</strong> La tranquilidad de saber que puedes resolver\n      una emergencia por tu cuenta.\n    </p>\n\n    <div class=\"klem-divider\"></div>\n\n  </section>\n</div>\n\n<script>\n(function(){\n  var lines = document.querySelectorAll('.klem-line');\n  var desc  = document.querySelector('.klem-desc');\n  var div   = document.querySelector('.klem-divider');\n\n  var obs = new IntersectionObserver(function(entries){\n    entries.forEach(function(e){\n      if(e.isIntersecting){\n        e.target.classList.add('klem-vis');\n        obs.unobserve(e.target);\n      }\n    });\n  }, { threshold: 0.2 });\n\n  lines.forEach(function(l){ obs.observe(l); });\n  if(desc) obs.observe(desc);\n  if(div)  obs.observe(div);\n})();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_jfVwKL": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.klaizo-features {\n  background: #000;\n  padding: 80px 20px;\n  display: flex;\n  justify-content: center;\n}\n\n.klaizo-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 30px;\n  max-width: 1100px;\n  width: 100%;\n}\n\n.klaizo-card {\n  position: relative;\n  border-radius: 20px;\n  overflow: hidden;\n  cursor: pointer;\n  transform: scale(0.95);\n  opacity: 0;\n  animation: fadeZoom 1s ease forwards;\n}\n\n.klaizo-card:nth-child(1) { animation-delay: 0.2s; }\n.klaizo-card:nth-child(2) { animation-delay: 0.4s; }\n\n.klaizo-card img {\n  width: 100%;\n  height: 420px;\n  object-fit: cover;\n  display: block;\n  transition: transform 0.5s ease;\n}\n\n.klaizo-card:hover img {\n  transform: scale(1.08);\n}\n\n.klaizo-overlay {\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.1));\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-end;\n  padding: 25px;\n}\n\n.klaizo-tag {\n  color: #ff3b3b;\n  font-size: 13px;\n  letter-spacing: 1px;\n  margin-bottom: 5px;\n  font-weight: 600;\n}\n\n.klaizo-text {\n  font-size: 20px;\n  font-weight: 600;\n  color: #fff;\n}\n\n@keyframes fadeZoom {\n  to {\n    opacity: 1;\n    transform: scale(1);\n  }\n}\n\n/* RESPONSIVE */\n@media (max-width: 768px) {\n  .klaizo-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .klaizo-card img {\n    height: 300px;\n  }\n}\n</style>\n\n<div class=\"klaizo-features\">\n  <div class=\"klaizo-grid\">\n\n    <!-- CARD COMPRESOR -->\n    <div class=\"klaizo-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0796/2581/4243/files/ChatGPT_Image_1_may_2026_07_50_08_p.m..png?v=1777738732\" alt=\"Compresor portátil\">\n      <div class=\"klaizo-overlay\">\n        <div class=\"klaizo-tag\">COMPRESOR</div>\n        <div class=\"klaizo-text\">Infla en minutos</div>\n      </div>\n    </div>\n\n    <!-- CARD ARRANQUE -->\n    <div class=\"klaizo-card\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0796/2581/4243/files/ChatGPT_Image_1_may_2026_07_57_48_p.m..png?v=1777738732\" alt=\"Arrancador de batería\">\n      <div class=\"klaizo-overlay\">\n        <div class=\"klaizo-tag\">ARRANQUE</div>\n        <div class=\"klaizo-text\">Tu auto vuelve a la vida</div>\n      </div>\n    </div>\n\n  </div>\n</div>",
