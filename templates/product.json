      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.kzmq * { box-sizing: border-box; margin: 0; padding: 0; }\n\n.kzmq-wrap {\n  background: linear-gradient(90deg, #8B0000 0%, #C1121F 50%, #8B0000 100%);\n  height: 48px;\n  overflow: hidden;\n  position: relative;\n  display: flex;\n  align-items: center;\n  /* Blur + glow rojo suave */\n  box-shadow:\n    0 2px 20px rgba(193,18,31,0.4),\n    0 1px 0 rgba(255,255,255,0.06) inset,\n    0 -1px 0 rgba(0,0,0,0.3) inset;\n}\n\n/* Fundidos laterales */\n.kzmq-wrap::before,\n.kzmq-wrap::after {\n  content: '';\n  position: absolute;\n  top: 0; bottom: 0;\n  width: 80px;\n  z-index: 2;\n  pointer-events: none;\n}\n.kzmq-wrap::before {\n  left: 0;\n  background: linear-gradient(to right, #8B0000, transparent);\n}\n.kzmq-wrap::after {\n  right: 0;\n  background: linear-gradient(to left, #8B0000, transparent);\n}\n\n/* Track animado */\n.kzmq-track {\n  display: flex;\n  width: max-content;\n  align-items: center;\n  animation: kzmqScroll 22s linear infinite;\n  will-change: transform;\n}\n.kzmq-track:hover {\n  animation-play-state: paused;\n}\n\n/* Grupo de items */\n.kzmq-group {\n  display: flex;\n  align-items: center;\n  flex-shrink: 0;\n}\n\n/* Item individual */\n.kzmq-item {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  padding: 0 32px;\n  font-family: 'Inter', 'Barlow', sans-serif;\n  font-size: 13px;\n  font-weight: 600;\n  color: rgba(255,255,255,0.92);\n  white-space: nowrap;\n  letter-spacing: 0.03em;\n  cursor: default;\n  transition: color 0.3s;\n}\n.kzmq-item:hover {\n  color: #ffffff;\n}\n\n/* Item destacado — micro-glow en oferta */\n.kzmq-item--highlight {\n  color: #ffffff;\n  text-shadow: 0 0 12px rgba(255,200,200,0.4);\n}\n.kzmq-item--highlight .kzmq-icon {\n  filter: drop-shadow(0 0 4px rgba(255,220,220,0.6));\n}\n\n/* Ícono */\n.kzmq-icon {\n  font-size: 14px;\n  line-height: 1;\n  flex-shrink: 0;\n}\n\n/* Separador */\n.kzmq-sep {\n  width: 3px; height: 3px;\n  background: rgba(255,255,255,0.3);\n  border-radius: 50%;\n  flex-shrink: 0;\n  margin: 0 4px;\n}\n\n/* Animación */\n@keyframes kzmqScroll {\n  from { transform: translateX(0); }\n  to   { transform: translateX(-50%); }\n}\n\n/* Mobile */\n@media (max-width: 640px) {\n  .kzmq-wrap { height: 42px; }\n  .kzmq-item { font-size: 12px; padding: 0 24px; gap: 7px; }\n  .kzmq-track { animation-duration: 28s; }\n}\n</style>\n\n<div class=\"kzmq\">\n  <div class=\"kzmq-wrap\">\n    <div class=\"kzmq-track\">\n\n      <!-- Grupo 1 -->\n      <div class=\"kzmq-group\">\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">🚚</span>\n          Envío gratis a todo Chile\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">🛡</span>\n          Garantía oficial de 30 días\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">⭐</span>\n          +3.000 conductores protegidos\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item kzmq-item--highlight\">\n          <span class=\"kzmq-icon\">⚡</span>\n          Oferta de lanzamiento activa\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">🔒</span>\n          Compra 100% segura\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">🚚</span>\n          Despacho rápido Chile\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n      </div>\n\n      <!-- Grupo 2 — copia exacta para loop infinito -->\n      <div class=\"kzmq-group\">\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">🚚</span>\n          Envío gratis a todo Chile\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">🛡</span>\n          Garantía oficial de 30 días\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">⭐</span>\n          +3.000 conductores protegidos\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item kzmq-item--highlight\">\n          <span class=\"kzmq-icon\">⚡</span>\n          Oferta de lanzamiento activa\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">🔒</span>\n          Compra 100% segura\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n        <div class=\"kzmq-item\">\n          <span class=\"kzmq-icon\">🚚</span>\n          Despacho rápido Chile\n        </div>\n        <div class=\"kzmq-sep\"></div>\n\n      </div>\n\n    </div>\n  </div>\n</div>",
