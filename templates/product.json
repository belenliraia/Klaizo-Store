    "custom_liquid_8PrRWM": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.klaizo-guarantee {\n  background: radial-gradient(circle at center, #1a0000 0%, #000 70%);\n  padding: 100px 20px;\n  text-align: center;\n  color: #fff;\n  font-family: 'Barlow', sans-serif;\n  position: relative;\n  overflow: hidden;\n}\n\n/* ICONO */\n.klaizo-icon {\n  width: 60px;\n  height: 60px;\n  margin: 0 auto 20px;\n  border: 2px solid #ff3b3b;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #ff3b3b;\n  font-size: 26px;\n  animation: pulseGlow 2s infinite;\n}\n\n/* TITULO */\n.klaizo-title {\n  font-size: 42px;\n  font-weight: 700;\n  margin-bottom: 15px;\n  opacity: 0;\n  transform: translateY(20px);\n  animation: fadeUp 0.8s ease forwards;\n  animation-delay: 0.2s;\n}\n\n/* TEXTO */\n.klaizo-text {\n  font-size: 16px;\n  color: #cfcfcf;\n  max-width: 600px;\n  margin: auto;\n  line-height: 1.6;\n  opacity: 0;\n  animation: fadeIn 1s ease forwards;\n  animation-delay: 0.6s;\n}\n\n/* EFECTO FONDO */\n.klaizo-guarantee::before {\n  content: \"\";\n  position: absolute;\n  width: 400px;\n  height: 400px;\n  background: radial-gradient(circle, rgba(255,59,59,0.15), transparent);\n  top: -100px;\n  left: 50%;\n  transform: translateX(-50%);\n  filter: blur(60px);\n}\n\n/* ANIMACIONES */\n@keyframes fadeUp {\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes fadeIn {\n  to {\n    opacity: 1;\n  }\n}\n\n@keyframes pulseGlow {\n  0% { box-shadow: 0 0 0px rgba(255,59,59,0.3); }\n  50% { box-shadow: 0 0 20px rgba(255,59,59,0.8); }\n  100% { box-shadow: 0 0 0px rgba(255,59,59,0.3); }\n}\n</style>\n\n<div class=\"klaizo-guarantee\">\n  \n  <div class=\"klaizo-icon\">\n    ✔\n  </div>\n\n  <div class=\"klaizo-title\">\n    30 días de garantía\n  </div>\n\n  <div class=\"klaizo-text\">\n    Si no quedas conforme, te devolvemos el 100% de tu dinero. Sin preguntas.\n    Tu tranquilidad es lo más importante.\n  </div>\n\n</div>",
