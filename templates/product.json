    "custom_liquid_PVUTCG": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<style>\n.kcp * { box-sizing: border-box; margin: 0; padding: 0; }\n\n.kcp-section {\n  position: relative;\n  background: #000;\n  padding: 140px 24px;\n  text-align: center;\n  overflow: hidden;\n  font-family: 'Barlow', sans-serif;\n}\n\n/* Imagen de fondo */\n.kcp-bg {\n  position: absolute;\n  inset: 0;\n  background: url('https://cdn.shopify.com/s/files/1/0796/2581/4243/files/ChatGPT_Image_1_may_2026_03_16_37_p.m..png?v=1777663012') center/cover no-repeat;\n  filter: brightness(0.2) saturate(0.8);\n  transform: scale(1.05);\n  z-index: 0;\n  transition: transform 8s ease;\n}\n.kcp-section:hover .kcp-bg {\n  transform: scale(1.08);\n}\n\n/* Overlay degradado encima de la imagen */\n.kcp-overlay {\n  position: absolute;\n  inset: 0;\n  background:\n    radial-gradient(ellipse 70% 60% at 50% 50%, rgba(180,20,10,0.3) 0%, transparent 65%),\n    linear-gradient(to bottom, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.55) 50%, rgba(0,0,0,0.85) 100%);\n  z-index: 1;\n  pointer-events: none;\n}\n\n/* Glow rojo central pulsante */\n.kcp-glow {\n  position: absolute;\n  top: 50%; left: 50%;\n  transform: translate(-50%, -50%);\n  width: 600px; height: 360px;\n  background: radial-gradient(ellipse at center,\n    rgba(220,30,20,0.4) 0%,\n    rgba(180,20,10,0.15) 40%,\n    transparent 70%\n  );\n  pointer-events: none;\n  z-index: 2;\n  animation: kcpGlowBreath 3.5s ease-in-out infinite;\n}\n\n@keyframes kcpGlowBreath {\n  0%,100% { opacity: 0.8; transform: translate(-50%, -50%) scale(1); }\n  50%      { opacity: 1;   transform: translate(-50%, -50%) scale(1.1); }\n}\n\n/* Fundidos superior e inferior */\n.kcp-fade-top {\n  position: absolute;\n  top: 0; left: 0; right: 0;\n  height: 140px;\n  background: linear-gradient(to bottom, #000 0%, transparent 100%);\n  z-index: 3;\n  pointer-events: none;\n}\n.kcp-fade-bottom {\n  position: absolute;\n  bottom: 0; left: 0; right: 0;\n  height: 140px;\n  background: linear-gradient(to top, #000 0%, transparent 100%);\n  z-index: 3;\n  pointer-events: none;\n}\n\n/* Contenido */\n.kcp-content {\n  position: relative;\n  z-index: 4;\n  max-width: 740px;\n  margin: 0 auto;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 36px;\n}\n\n/* Título */\n.kcp-title {\n  font-size: clamp(36px, 6vw, 72px);\n  font-weight: 900;\n  line-height: 1.08;\n  color: #fff;\n  letter-spacing: -0.02em;\n  text-shadow: 0 2px 40px rgba(0,0,0,0.8);\n  opacity: 0;\n  transform: translateY(32px);\n  transition: opacity 0.8s ease, transform 0.8s ease;\n}\n.kcp-title.kcp-vis {\n  opacity: 1;\n  transform: translateY(0);\n}\n.kcp-title em {\n  font-style: normal;\n  color: #e8392a;\n  text-shadow: 0 0 30px rgba(232,57,42,0.4);\n}\n\n/* Botón */\n.kcp-btn {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  background: #e8392a;\n  color: #fff;\n  font-family: 'Barlow', sans-serif;\n  font-size: 17px;\n  font-weight: 700;\n  padding: 18px 44px;\n  border-radius: 100px;\n  text-decoration: none;\n  letter-spacing: 0.01em;\n  position: relative;\n  overflow: hidden;\n  opacity: 0;\n  transform: translateY(20px);\n  transition: opacity 0.8s 0.2s ease, transform 0.8s 0.2s ease, background 0.2s;\n}\n.kcp-btn.kcp-vis {\n  opacity: 1;\n  transform: translateY(0);\n  animation: kcpPulse 2.2s 0.5s ease-in-out infinite;\n}\n\n.kcp-btn::after {\n  content: '';\n  position: absolute;\n  top: 0; left: -70%;\n  width: 40%; height: 100%;\n  background: rgba(255,255,255,0.15);\n  transform: skewX(-20deg);\n  animation: kcpShine 2.8s ease-in-out infinite;\n}\n\n@keyframes kcpPulse {\n  0%,100% { box-shadow: 0 0 20px rgba(232,57,42,0.5), 0 0 40px rgba(232,57,42,0.2); }\n  50%      { box-shadow: 0 0 40px rgba(232,57,42,0.9), 0 0 80px rgba(232,57,42,0.4); }\n}\n@keyframes kcpShine {\n  0%   { left: -70%; }\n  55%  { left: 130%; }\n  100% { left: 130%; }\n}\n\n.kcp-btn:hover {\n  background: #ff1a2e;\n  transform: scale(1.05) translateY(-2px);\n  animation: none;\n  box-shadow: 0 0 50px rgba(232,57,42,1), 0 0 100px rgba(232,57,42,0.5);\n}\n.kcp-btn:active { transform: scale(0.98); }\n.kcp-btn svg { width: 20px; height: 20px; flex-shrink: 0; }\n\n/* Trust badges */\n.kcp-trust {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n  flex-wrap: wrap;\n  justify-content: center;\n  opacity: 0;\n  transform: translateY(16px);\n  transition: opacity 0.8s 0.35s ease, transform 0.8s 0.35s ease;\n}\n.kcp-trust.kcp-vis { opacity: 1; transform: translateY(0); }\n\n.kcp-trust-item {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  font-size: 12px;\n  color: rgba(255,255,255,0.5);\n  font-weight: 600;\n  letter-spacing: 0.03em;\n}\n.kcp-trust-item svg { width: 13px; height: 13px; color: rgba(232,57,42,0.7); flex-shrink: 0; }\n\n/* Responsive */\n@media (max-width: 640px) {\n  .kcp-section { padding: 100px 20px; }\n  .kcp-glow { width: 320px; height: 220px; }\n  .kcp-btn {\n    font-size: 16px;\n    padding: 16px 28px;\n    width: 100%;\n    justify-content: center;\n    border-radius: 14px;\n  }\n  .kcp-trust { gap: 10px 16px; }\n  .kcp-trust-item { font-size: 11px; }\n}\n</style>\n\n<div class=\"kcp\">\n  <section class=\"kcp-section\">\n    <div class=\"kcp-bg\"></div>\n    <div class=\"kcp-overlay\"></div>\n    <div class=\"kcp-glow\"></div>\n    <div class=\"kcp-fade-top\"></div>\n    <div class=\"kcp-fade-bottom\"></div>\n\n    <div class=\"kcp-content\">\n      <h2 class=\"kcp-title\">\n        Tu próximo viaje<br>merece un<br><em>copiloto confiable.</em>\n      </h2>\n\n      <a href=\"https://klaizo.com/products/partidor-bateria-auto-compresor-multifun\" class=\"kcp-btn\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"/>\n        </svg>\n        Comprar KLAIZO PowerGo\n      </a>\n\n      <div class=\"kcp-trust\">\n        <div class=\"kcp-trust-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n          Envío gratis\n        </div>\n        <div class=\"kcp-trust-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n          Garantía 30 días\n        </div>\n        <div class=\"kcp-trust-item\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><rect x=\"1\" y=\"4\" width=\"22\" height=\"16\" rx=\"2\"/><line x1=\"1\" y1=\"10\" x2=\"23\" y2=\"10\"/></svg>\n          Pago 100% seguro\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n<script>\n(function(){\n  var els = document.querySelectorAll('.kcp-title, .kcp-btn, .kcp-trust');\n  if(!els.length) return;\n  var obs = new IntersectionObserver(function(entries){\n    entries.forEach(function(e){\n      if(e.isIntersecting){\n        e.target.classList.add('kcp-vis');\n        obs.unobserve(e.target);\n      }\n    });\n  }, { threshold: 0.2 });\n  els.forEach(function(el){ obs.observe(el); });\n})();\n</script>",
